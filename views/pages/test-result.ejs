<%- include("../partials/head", { title }) %>

<section class="panel">
  <div class="panel__top">
    <div class="panel__kicker">측정 완료</div>
    <h1 class="panel__title"><%= userName %> 님의 유형은</h1>
  </div>

  <div class="result">
    <div class="result__left">
      <div class="pogeunbunny pogeunbunny--big" style="--pt:<%= meta.color %>">
        <div class="pogeunbunny__face"></div>
      </div>
    </div>
    <div class="result__right">
      <div class="badge" style="--badge:<%= meta.color %>"><%= mbti %></div>
      <div class="result__label"><%= meta.label %></div>
      <div class="result__vibe"><%= meta.vibe %></div>
      <div class="result__meta">
        <div class="pill">저장 ID #<%= resultId %></div>
      </div>
    </div>
  </div>

  <div class="scores">
    <div class="scores__title">스코어</div>
    <div class="scores__grid">
      <div class="score">
        <div class="score__k">E / I</div>
        <div class="score__v"><b><%= scores.EI.A %></b> : <%= scores.EI.B %></div>
      </div>
      <div class="score">
        <div class="score__k">S / N</div>
        <div class="score__v"><b><%= scores.SN.A %></b> : <%= scores.SN.B %></div>
      </div>
      <div class="score">
        <div class="score__k">T / F</div>
        <div class="score__v"><b><%= scores.TF.A %></b> : <%= scores.TF.B %></div>
      </div>
      <div class="score">
        <div class="score__k">J / P</div>
        <div class="score__v"><b><%= scores.JP.A %></b> : <%= scores.JP.B %></div>
      </div>
    </div>
  </div>

  <div class="actions">
    <form method="post" action="/test/restart" class="inline">
      <button class="btn btn--ghost" type="submit">다시 측정</button>
    </form>
    <a class="btn btn--primary" href="/results">결과 목록</a>
  </div>

  <div class="actions actions--stack">
    <a class="btn btn--full btn--ghost" href="/types">전체 성격 유형 보기</a>
    <a class="btn btn--full btn--ghost" href="/admin/questions">질문 수정(관리)</a>
  </div>
</section>

<%- include("../partials/foot") %>

